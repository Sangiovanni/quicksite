# Test directory (comprehensive test suite)
tests/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Debug scripts
debug_*.py

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# AI agent instructions (local only)
.github/copilot-instructions.md

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Build artifacts
build/
dist/
*.egg-info/

# Environment variables
.env
.env.local

# Temporary files
tmp/
temp/
*.tmp

# Personal notes
NOTES/

# Stats files (project metrics)
stats/

# Projects folder - ignore all except quicksite (starter template)
secure/projects/*
!secure/projects/quicksite/

# Ignore backups inside quicksite too (user data)
secure/projects/quicksite/backups/

# Management config - local/sensitive files (use .example templates for setup)
secure/management/config/target.php
secure/management/config/auth.php
secure/management/config/roles.php

# Exports folder (temporary export ZIPs)
secure/exports/

# Nginx config (auto-generated per install)
secure/nginx/

# Custom workflows (user-created, not shipped with QuickSite)
secure/admin/workflows/custom/*
!secure/admin/workflows/custom/.gitkeep

# Setup config (generated by setup.sh / setup.bat)
.quicksite.conf

# Build output
public/build/

# Generated sitemap files (per-project, regenerated via admin)
public/sitemap.txt
secure/projects/quicksite/public/sitemap.txt

# Logs
secure/logs/