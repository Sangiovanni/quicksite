# Test directory (comprehensive test suite)
tests/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Debug scripts
debug_*.py

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# AI agent instructions (local only)
.github/copilot-instructions.md
CLAUDE.md
CLAUDE.local.md

# Claude Code local state (worktrees, session data)
.claude/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Build artifacts
build/
dist/
*.egg-info/

# Environment variables
.env
.env.local

# Temporary files
tmp/
temp/
*.tmp

# Personal notes
NOTES/

# Stats files (project metrics)
stats/

# Dev-time helper: one-shot URL that calls opcache_reset() so changes
# to routes.php / command files take effect without restarting WAMP
# or killing php-cgi.exe workers. Its own header says "Remove from
# public/ before any deploy" — must not ship in commits.
public/opcache-reset.php

# Projects folder - ignore all except quicksite (starter template)
secure/projects/*
!secure/projects/quicksite/

# Ignore backups inside quicksite too (user data)
secure/projects/quicksite/backups/

# Management config - local/sensitive files (use .example templates for setup)
secure/management/config/target.php
secure/management/config/auth.php
secure/management/config/roles.php

# Admin config - server-side secrets for data resolver (beta.8 A2).
# Gitignored by design — anyone with filesystem access to secure/ can
# read these. Ship secure/admin/config/api-secrets.php.example as the
# template; deployments copy + rename to api-secrets.php and populate.
secure/admin/config/api-secrets.php

# Resolver response cache (beta.8 A2 Slice 4). File-based TTL cache for
# the server-side data resolver. Per-deployment runtime state — never
# committed. cleanResolverCache command handles housekeeping; editApi
# auto-clears on endpoint config change.
secure/cache/resolver/

# Exports folder (temporary export ZIPs)
secure/exports/

# Nginx config (auto-generated per install)
secure/nginx/

# Custom workflows (user-created, not shipped with QuickSite)
secure/admin/workflows/custom/*
!secure/admin/workflows/custom/.gitkeep

# Custom snippets (user-created global snippets, not shipped with QuickSite)
secure/snippets/custom/*
!secure/snippets/custom/.gitkeep

# Setup config (generated by setup.sh / setup.bat)
.quicksite.conf

# Build output
public/build/

# Generated sitemap files (per-project, regenerated via admin)
public/sitemap.txt
secure/projects/quicksite/public/sitemap.txt

# Logs
secure/logs/