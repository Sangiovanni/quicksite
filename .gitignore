# Test directory (comprehensive test suite)
tests/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Debug scripts
debug_*.py

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
ENV/
.venv

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# AI agent instructions (local only)
.github/copilot-instructions.md
CLAUDE.md
CLAUDE.local.md

# Claude Code local state (worktrees, session data)
.claude/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Build artifacts
build/
dist/
*.egg-info/

# Environment variables
.env
.env.local

# Temporary files
tmp/
temp/
*.tmp

# Personal notes
NOTES/

# Stats files (project metrics)
stats/

# Dev-time helper: one-shot URL that calls opcache_reset() so changes
# to routes.php / command files take effect without restarting WAMP
# or killing php-cgi.exe workers. Its own header says "Remove from
# public/ before any deploy" — must not ship in commits.
public/opcache-reset.php

# Projects folder - ignore all except quicksite (starter template)
secure/projects/*
!secure/projects/quicksite/

# Ignore backups inside quicksite too (user data)
secure/projects/quicksite/backups/

# Management config - local/sensitive files (use .example templates for setup)
secure/management/config/auth.php
secure/management/config/users.php
secure/management/config/roles.php
secure/management/config/deploy-roots.php
secure/management/config/environment.php

# Session + login/registration-throttle runtime state (C5b/C8) -
# machine-written JSON (auto-created; holds sha256-hashed session tokens +
# hashed-key backoff counters) plus flock sidecars and atomic-write temp
# files (users.php.lock = the C8 centralized users-writer's sidecar).
secure/management/config/sessions.json
secure/management/config/login-throttle.json
secure/management/config/registration-throttle.json
secure/management/config/*.json.lock
secure/management/config/*.tmp*
secure/management/config/users.php.lock

# Admin config - server-side secrets for data resolver (beta.8 A2) +
# OAuth provider credentials (beta.9 A1).
# Gitignored by design — anyone with filesystem access to secure/ can
# read these. Ship the .example sibling as the template; deployments
# copy + rename to the live filename and populate.
secure/admin/config/api-secrets.php
secure/admin/config/oauth-secrets.php

# Per-project OAuth credentials (beta.9 A1 Slice 2.5 — primary lookup
# before falling back to the admin-level file above). The
# secure/projects/* tree is already gitignored EXCEPT the quicksite
# starter template; this re-ignores the secrets file inside the template
# explicitly so a copy-and-rename setup in the template can't accidentally
# leak credentials at commit time.
secure/projects/quicksite/data/oauth-secrets.json

# Per-project membership/access file (C5). Install-local — references userIds
# generated at migration/bootstrap, meaningless without the local users.php.
# The secure/projects/* tree is gitignored EXCEPT the quicksite starter template,
# so re-ignore the template's members.json explicitly (like oauth-secrets above).
# The .lock sibling is qs_members_mutate's flock sidecar (C8 8.3a).
secure/projects/quicksite/config/members.json
secure/projects/quicksite/config/members.json.lock

# Resolver response cache (beta.8 A2 Slice 4). File-based TTL cache for
# the server-side data resolver. Per-deployment runtime state — never
# committed. cleanResolverCache command handles housekeeping; editApi
# auto-clears on endpoint config change.
secure/cache/resolver/

# Owner space-usage cache (beta.10 C8 8.5b). Measured per-project disk sizes
# behind getMySpaceUsage. Per-deployment runtime state — never committed.
# Entries expire on a TTL, are pruned when their project disappears, and
# getMySpaceUsage's refresh=true rewrites them.
secure/cache/space/

# Exports folder — legacy shared location. Exports moved under each project in
# beta.10 C8 8.5 (secure/projects/<id>/exports/); both are runtime artifacts.
secure/exports/
secure/projects/*/exports/

# Nginx config (auto-generated per install)
secure/nginx/

# Custom workflows (user-created, not shipped with QuickSite)
secure/admin/workflows/custom/*
!secure/admin/workflows/custom/.gitkeep

# Custom snippets (user-created global snippets, not shipped with QuickSite)
secure/snippets/custom/*
!secure/snippets/custom/.gitkeep

# Setup config (generated by setup.sh / setup.bat)
.quicksite.conf

# Build output (per-project)
secure/projects/*/public/build/

# Generated sitemap files (per-project, regenerated via admin)
secure/projects/quicksite/public/sitemap.txt

# Generated client artifacts — the qs-*.js trio (API config, enums, route schema) is
# COMPILED from each project's own data and rewritten whenever that data changes. Every
# project generates its own on first serve, so committing them would mean a permanent
# stream of machine-written diffs that nobody reads and that conflict on every merge.
# The hand-written engine runtime (secure/src/runtime/qs.js) is source and IS tracked.
secure/projects/*/public/scripts/qs-*.js

# Logs
secure/logs/