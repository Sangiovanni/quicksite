{
    "$schema": "../schema.json",
    "id": "quicksite-v2-assets-test",
    "version": "1.0.0",
    "meta": {
        "icon": "\ud83d\uddbc\ufe0f",
        "name": "QuickSite v2 Assets test",
        "description": "Upload the default QuickSite template images from the GitHub repository.",
        "category": "template",
        "difficulty": "beginner",
        "tags": [
            "assets",
            "images",
            "template",
            "setup"
        ]
    },
    "relatedCommands": [
        "uploadAsset"
    ],
    "steps": [
        {
            "comment": "Upload 404 page image",
            "command": "uploadAsset",
            "params": {
                "url": "https://raw.githubusercontent.com/Sangiovanni/quicksite/main/docs/404.png",
                "alt": "404 page illustration",
                "description": "Image displayed on the 404 error page"
            }
        },
        {
            "comment": "Upload documentation image",
            "command": "uploadAsset",
            "params": {
                "url": "https://raw.githubusercontent.com/Sangiovanni/quicksite/main/docs/documentation.png",
                "alt": "Documentation illustration",
                "description": "Image used on the documentation page"
            }
        },
        {
            "comment": "Upload favicon",
            "command": "uploadAsset",
            "params": {
                "url": "https://raw.githubusercontent.com/Sangiovanni/quicksite/main/docs/favicon.png",
                "alt": "QuickSite favicon",
                "description": "Default QuickSite favicon image"
            }
        },
        {
            "comment": "Upload GitHub logo",
            "command": "uploadAsset",
            "params": {
                "url": "https://raw.githubusercontent.com/Sangiovanni/quicksite/main/docs/git-hub-logo-white.png",
                "alt": "GitHub logo white",
                "description": "White GitHub logo for dark backgrounds"
            }
        },
        {
            "comment": "Upload home page image",
            "command": "uploadAsset",
            "params": {
                "url": "https://raw.githubusercontent.com/Sangiovanni/quicksite/main/docs/home.png",
                "alt": "Home page illustration",
                "description": "Image displayed on the home page"
            }
        },
        {
            "comment": "Upload site logo",
            "command": "uploadAsset",
            "params": {
                "url": "https://raw.githubusercontent.com/Sangiovanni/quicksite/main/docs/logo.png",
                "alt": "QuickSite logo",
                "description": "Default QuickSite template logo"
            }
        }
    ]
}