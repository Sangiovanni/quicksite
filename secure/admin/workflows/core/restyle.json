{
    "$schema": "../schema.json",
    "id": "restyle",
    "version": "1.0.0",
    "meta": {
        "icon": "✨",
        "titleKey": "ai.specs.restyle.title",
        "descriptionKey": "ai.specs.restyle.description",
        "category": "style",
        "tags": ["style", "css", "redesign", "visual"],
        "difficulty": "intermediate"
    },
    "parameters": [],
    "dataRequirements": [
        {
            "id": "rootVariables",
            "command": "getRootVariables",
            "extract": "data.variables"
        },
        {
            "id": "styles",
            "command": "getStyles",
            "extract": "data"
        },
        {
            "id": "helpEditStyles",
            "command": "help",
            "urlParams": ["editStyles"],
            "extract": "data"
        },
        {
            "id": "helpSetRootVariables",
            "command": "help",
            "urlParams": ["setRootVariables"],
            "extract": "data"
        }
    ],
    "relatedCommands": ["editStyles", "setRootVariables"],
    "promptTemplate": "restyle.md"
}
