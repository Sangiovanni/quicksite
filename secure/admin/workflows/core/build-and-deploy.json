{
    "$schema": "../schema.json",
    "id": "build-and-deploy",
    "version": "1.0.0",
    "meta": {
        "icon": "🚀",
        "titleKey": "workflows.specs.buildAndDeploy.title",
        "descriptionKey": "workflows.specs.buildAndDeploy.description",
        "category": "advanced",
        "tags": ["build", "deploy", "production"],
        "difficulty": "intermediate"
    },
    "parameters": [
        {
            "id": "buildName",
            "type": "text",
            "labelKey": "workflows.specs.buildAndDeploy.params.buildName.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.buildName.help",
            "placeholderKey": "workflows.specs.buildAndDeploy.params.buildName.placeholder",
            "default": ""
        },
        {
            "id": "buildExists",
            "type": "hidden",
            "default": "false"
        },
        {
            "id": "publicFolder",
            "type": "text",
            "labelKey": "workflows.specs.buildAndDeploy.params.publicFolder.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.publicFolder.help",
            "placeholderKey": "workflows.specs.buildAndDeploy.params.publicFolder.placeholder",
            "default": "public"
        },
        {
            "id": "secureFolder",
            "type": "text",
            "labelKey": "workflows.specs.buildAndDeploy.params.secureFolder.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.secureFolder.help",
            "placeholderKey": "workflows.specs.buildAndDeploy.params.secureFolder.placeholder",
            "default": "secure"
        },
        {
            "id": "spaceFolder",
            "type": "text",
            "labelKey": "workflows.specs.buildAndDeploy.params.spaceFolder.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.spaceFolder.help",
            "placeholderKey": "workflows.specs.buildAndDeploy.params.spaceFolder.placeholder",
            "default": ""
        },
        {
            "id": "customTarget",
            "type": "checkbox",
            "labelKey": "workflows.specs.buildAndDeploy.params.customTarget.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.customTarget.help",
            "default": false
        },
        {
            "id": "targetPath",
            "type": "text",
            "labelKey": "workflows.specs.buildAndDeploy.params.targetPath.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.targetPath.help",
            "placeholderKey": "workflows.specs.buildAndDeploy.params.targetPath.placeholder",
            "condition": "customTarget === true",
            "default": ""
        },
        {
            "id": "deletePrevious",
            "type": "checkbox",
            "labelKey": "workflows.specs.buildAndDeploy.params.deletePrevious.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.deletePrevious.help",
            "default": false
        },
        {
            "id": "overwrite",
            "type": "checkbox",
            "labelKey": "workflows.specs.buildAndDeploy.params.overwrite.label",
            "helpKey": "workflows.specs.buildAndDeploy.params.overwrite.help",
            "default": false
        }
    ],
    "loadPreset": {
        "command": "listBuilds",
        "dataPath": "builds",
        "labelKey": "workflows.specs.buildAndDeploy.loadPreset.label",
        "placeholderKey": "workflows.specs.buildAndDeploy.loadPreset.placeholder",
        "valueField": "name",
        "setParam": "buildExists",
        "fieldMap": {
            "buildName": "name",
            "publicFolder": "public",
            "secureFolder": "secure",
            "spaceFolder": "space"
        }
    },
    "relatedCommands": ["build", "deployBuild", "deleteBuild"],
    "steps": [
        {
            "comment": "=== PHASE 0: DELETE EXISTING BUILD (optional) ===",
            "command": "deleteBuild",
            "method": "DELETE",
            "condition": "param.deletePrevious === true",
            "abortOnFail": false,
            "params": {
                "name": "{{param.buildName}}"
            }
        },
        {
            "comment": "=== PHASE 1: BUILD (skip if using existing build) ===",
            "command": "build",
            "method": "POST",
            "condition": "param.buildExists !== true",
            "abortOnFail": true,
            "params": {
                "name": "{{param.buildName}}",
                "public": "{{param.publicFolder}}",
                "secure": "{{param.secureFolder}}",
                "space": "{{param.spaceFolder}}"
            }
        },
        {
            "comment": "=== PHASE 2: DEPLOY ===",
            "command": "deployBuild",
            "method": "POST",
            "abortOnFail": true,
            "retryOn": [409],
            "maxRetries": 3,
            "retryDelayMs": 2000,
            "params": {
                "name": "{{param.buildName}}",
                "targetPath": "{{param.targetPath}}",
                "overwrite": "{{param.overwrite}}"
            }
        }
    ]
}
