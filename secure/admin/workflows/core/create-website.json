{
    "$schema": "../schema.json",
    "id": "create-website",
    "version": "1.0.0",
    "meta": {
        "icon": "🌐",
        "titleKey": "ai.specs.createWebsite.title",
        "descriptionKey": "ai.specs.createWebsite.description",
        "category": "creation",
        "tags": ["create", "website", "multi-page", "from-scratch"],
        "difficulty": "advanced"
    },
    "parameters": [
        {
            "id": "multilingual",
            "type": "checkbox",
            "labelKey": "ai.specs.createWebsite.params.multilingual.label",
            "helpKey": "ai.specs.createWebsite.params.multilingual.help",
            "default": true
        },
        {
            "id": "languages",
            "type": "text",
            "labelKey": "ai.specs.createWebsite.params.languages.label",
            "placeholderKey": "ai.specs.createWebsite.params.languages.placeholder",
            "helpKey": "ai.specs.createWebsite.params.languages.help",
            "default": "en",
            "condition": "multilingual === true"
        },
        {
            "id": "pages",
            "type": "text",
            "labelKey": "ai.specs.createWebsite.params.pages.label",
            "placeholderKey": "ai.specs.createWebsite.params.pages.placeholder",
            "helpKey": "ai.specs.createWebsite.params.pages.help",
            "default": "home, about, services, contact"
        },
        {
            "id": "includeAssets",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.includeAssets.label",
            "helpKey": "ai.specs.shared.params.includeAssets.help",
            "default": false
        },
        {
            "id": "includeFavicon",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.includeFavicon.label",
            "helpKey": "ai.specs.shared.params.includeFavicon.help",
            "default": false,
            "condition": "includeAssets === true"
        },
        {
            "id": "keepAssets",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.keepAssets.label",
            "helpKey": "ai.specs.shared.params.keepAssets.help",
            "default": true
        },
        {
            "id": "keepLanguages",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.keepLanguages.label",
            "helpKey": "ai.specs.shared.params.keepLanguages.help",
            "default": true
        }
    ],
    "dataRequirements": [
        {
            "id": "helpSetMultilingual",
            "command": "help",
            "urlParams": ["setMultilingual"],
            "extract": "data",
            "condition": "multilingual === true"
        },
        {
            "id": "helpAddLang",
            "command": "help",
            "urlParams": ["addLang"],
            "extract": "data",
            "condition": "multilingual === true"
        },
        {
            "id": "helpAddRoute",
            "command": "help",
            "urlParams": ["addRoute"],
            "extract": "data"
        },
        {
            "id": "helpEditStructure",
            "command": "help",
            "urlParams": ["editStructure"],
            "extract": "data"
        },
        {
            "id": "helpSetTranslationKeys",
            "command": "help",
            "urlParams": ["setTranslationKeys"],
            "extract": "data"
        },
        {
            "id": "helpEditStyles",
            "command": "help",
            "urlParams": ["editStyles"],
            "extract": "data"
        },
        {
            "id": "helpSetRootVariables",
            "command": "help",
            "urlParams": ["setRootVariables"],
            "extract": "data"
        },
        {
            "id": "assetList",
            "command": "listAssets",
            "urlParams": ["starred"],
            "extract": "data",
            "condition": "includeAssets === true"
        },
        {
            "id": "helpEditFavicon",
            "command": "help",
            "urlParams": ["editFavicon"],
            "extract": "data",
            "condition": "includeAssets === true && includeFavicon === true"
        }
    ],
    "relatedCommands": ["setMultilingual", "addLang", "addRoute", "editStructure", "setTranslationKeys", "editStyles", "setRootVariables", "editFavicon"],
    "preWorkflows": [
        {
            "id": "fresh-start",
            "params": {
                "keepAssets": "{{param.keepAssets}}",
                "keepLanguages": "{{param.keepLanguages}}"
            }
        }
    ],
    "postWorkflows": [
        {
            "id": "update-lang-switch",
            "condition": "param.multilingual === true"
        }
    ],
    "promptTemplate": "create-website.md"
}
