{
    "$schema": "../schema.json",
    "id": "create-website",
    "version": "1.1.0",
    "meta": {
        "icon": "🌐",
        "titleKey": "ai.specs.createWebsite.title",
        "descriptionKey": "ai.specs.createWebsite.description",
        "category": "creation",
        "tags": ["create", "website", "multi-page", "from-scratch"],
        "difficulty": "advanced"
    },
    "parameters": [
        {
            "id": "multilingual",
            "type": "checkbox",
            "labelKey": "workflows.specs.setupLanguages.params.multilingual.label",
            "helpKey": "workflows.specs.setupLanguages.params.multilingual.help",
            "default": false
        },
        {
            "id": "languages",
            "type": "tag-select",
            "labelKey": "workflows.specs.setupLanguages.params.languages.label",
            "helpKey": "workflows.specs.setupLanguages.params.languages.help",
            "placeholderKey": "workflows.specs.setupLanguages.params.languages.placeholder",
            "optionsFrom": {
                "data": "allLanguages",
                "value": "code",
                "label": "name"
            },
            "default": "en",
            "condition": "multilingual === true"
        },
        {
            "id": "defaultLanguage",
            "type": "select",
            "labelKey": "workflows.specs.setupLanguages.params.defaultLanguage.label",
            "helpKey": "workflows.specs.setupLanguages.params.defaultLanguage.help",
            "optionsFrom": {
                "data": "allLanguages",
                "value": "code",
                "label": "name"
            },
            "default": "en"
        },
        {
            "id": "includeAssets",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.includeAssets.label",
            "helpKey": "ai.specs.shared.params.includeAssets.help",
            "default": false
        },
        {
            "id": "includeFavicon",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.includeFavicon.label",
            "helpKey": "ai.specs.shared.params.includeFavicon.help",
            "default": false,
            "condition": "includeAssets === true"
        },
        {
            "id": "keepAssets",
            "type": "checkbox",
            "labelKey": "ai.specs.shared.params.keepAssets.label",
            "helpKey": "ai.specs.shared.params.keepAssets.help",
            "default": true
        }
    ],
    "dataRequirements": [
        {
            "id": "allLanguages",
            "command": "getLanguageList",
            "extract": "data.languages"
        },
        {
            "id": "helpAddRoute",
            "command": "help",
            "urlParams": ["addRoute"],
            "extract": "data"
        },
        {
            "id": "helpEditStructure",
            "command": "help",
            "urlParams": ["editStructure"],
            "extract": "data"
        },
        {
            "id": "helpSetTranslationKeys",
            "command": "help",
            "urlParams": ["setTranslationKeys"],
            "extract": "data"
        },
        {
            "id": "helpEditStyles",
            "command": "help",
            "urlParams": ["editStyles"],
            "extract": "data"
        },
        {
            "id": "helpSetRootVariables",
            "command": "help",
            "urlParams": ["setRootVariables"],
            "extract": "data"
        },
        {
            "id": "assetList",
            "command": "listAssets",
            "urlParams": ["starred"],
            "extract": "data",
            "condition": "includeAssets === true"
        },
        {
            "id": "helpEditFavicon",
            "command": "help",
            "urlParams": ["editFavicon"],
            "extract": "data",
            "condition": "includeAssets === true && includeFavicon === true"
        }
    ],
    "relatedCommands": ["addRoute", "editStructure", "setTranslationKeys", "editStyles", "setRootVariables", "editFavicon"],
    "preWorkflows": [
        {
            "id": "fresh-start",
            "params": {
                "keepAssets": "{{param.keepAssets}}",
                "keepLanguages": false
            }
        },
        {
            "id": "setup-languages",
            "params": {
                "multilingual": "{{param.multilingual}}",
                "languages": "{{param.languages}}",
                "defaultLanguage": "{{param.defaultLanguage}}"
            }
        }
    ],
    "postWorkflows": [
        {
            "id": "update-lang-switch",
            "condition": "param.multilingual === true"
        }
    ],
    "promptTemplate": "create-website.md"
}
