{
    "$schema": "../schema.json",
    "id": "setup-languages",
    "version": "1.0.0",
    "meta": {
        "icon": "🌐",
        "titleKey": "workflows.specs.setupLanguages.title",
        "descriptionKey": "workflows.specs.setupLanguages.description",
        "category": "modification",
        "tags": ["language", "multilingual", "i18n", "setup"],
        "difficulty": "beginner"
    },
    "parameters": [
        {
            "id": "multilingual",
            "type": "checkbox",
            "labelKey": "workflows.specs.setupLanguages.params.multilingual.label",
            "helpKey": "workflows.specs.setupLanguages.params.multilingual.help",
            "default": "{{data.langData.multilingual_enabled}}"
        },
        {
            "id": "languages",
            "type": "tag-select",
            "labelKey": "workflows.specs.setupLanguages.params.languages.label",
            "helpKey": "workflows.specs.setupLanguages.params.languages.help",
            "optionsFrom": {
                "data": "allLanguages",
                "value": "code",
                "label": "name"
            },
            "default": "{{data.langData.languages}}",
            "condition": "multilingual === true",
            "validation": {
                "minItems": 2
            }
        },
        {
            "id": "defaultLanguage",
            "type": "select",
            "labelKey": "workflows.specs.setupLanguages.params.defaultLanguage.label",
            "helpKey": "workflows.specs.setupLanguages.params.defaultLanguage.help",
            "optionsFrom": {
                "data": "allLanguages",
                "value": "code",
                "label": "name",
                "filterFrom": "languages"
            },
            "default": "{{data.langData.default_language}}"
        }
    ],
    "dataRequirements": [
        {
            "id": "allLanguages",
            "command": "getLanguageList",
            "extract": "data.languages"
        },
        {
            "id": "langData",
            "command": "getLangList",
            "extract": "data"
        }
    ],
    "relatedCommands": ["addLang", "deleteLang", "setDefaultLang", "setMultilingual"],
    "steps": [
        {
            "comment": "=== MULTI-LANG PHASE 1: Enable multilingual support ===",
            "condition": "param.multilingual === true",
            "command": "setMultilingual",
            "params": {
                "enabled": true
            }
        },
        {
            "comment": "=== MULTI-LANG PHASE 2: Add only the languages the user picked that aren't already present ===",
            "condition": "param.multilingual === true",
            "forEach": "param.languages",
            "filter": "{{$value}} not_in {{data.langData.languages}}",
            "command": "addLang",
            "params": {
                "code": "{{$value}}"
            }
        },
        {
            "comment": "=== MULTI-LANG PHASE 3: Remove only the languages currently present that the user un-picked ===",
            "condition": "param.multilingual === true",
            "forEach": "data.langData.languages",
            "filter": "{{$value}} not_in {{param.languages}}",
            "command": "deleteLang",
            "params": {
                "code": "{{$value}}"
            }
        },
        {
            "comment": "=== SINGLE-LANG PHASE 1: Add the chosen base language (no-op if already present) ===",
            "condition": "param.multilingual !== true",
            "command": "addLang",
            "params": {
                "code": "{{param.defaultLanguage}}"
            }
        },
        {
            "comment": "=== SINGLE-LANG PHASE 2: Temporarily enable multilingual so we can change the default + delete extras ===",
            "condition": "param.multilingual !== true && param.defaultLanguage !== langData.default_language",
            "command": "setMultilingual",
            "params": {
                "enabled": true
            }
        },
        {
            "comment": "=== SHARED PHASE 4: Set default language (only when different from current) ===",
            "condition": "param.defaultLanguage !== langData.default_language",
            "command": "setDefaultLang",
            "params": {
                "lang": "{{param.defaultLanguage}}"
            }
        },
        {
            "comment": "=== SINGLE-LANG PHASE 5: Delete every existing language except the chosen default ===",
            "condition": "param.multilingual !== true",
            "forEach": "data.langData.languages",
            "filter": "{{$value}} !== {{param.defaultLanguage}}",
            "command": "deleteLang",
            "params": {
                "code": "{{$value}}"
            }
        },
        {
            "comment": "=== SINGLE-LANG PHASE 6: Disable multilingual now that only one language remains ===",
            "condition": "param.multilingual !== true",
            "command": "setMultilingual",
            "params": {
                "enabled": false
            }
        }
    ]
}
