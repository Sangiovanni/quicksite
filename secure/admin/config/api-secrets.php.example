<?php
/**
 * api-secrets.php — Server-side API secrets registry (beta.8 A2).
 *
 * Used by the server-side data resolver (DataResolver / serverFetch) when
 * an endpoint's auth type is `apiKey` and `callableFrom: server` (or `both`).
 * The resolver looks up the secret by the calling endpoint's `apiId`.
 *
 *
 * SECURITY DISCLOSURE — read before committing this file's `.php` sibling:
 * (locked Q2 in NOTES/planning/BETA8_DATA_RESOLVER.md, 2026-06-04)
 *
 *   Anyone with FILESYSTEM access to `secure/` can read these secrets.
 *   That is BY DESIGN — server-side PHP code needs them to call upstream
 *   APIs. But it means:
 *
 *     1. DO NOT put `secure/` inside any directory that the web server
 *        serves. The split between `public/` (web-served) and `secure/`
 *        (require_once-only) exists exactly for this reason — see
 *        ARCHITECTURE.md §7 "Security boundary".
 *
 *     2. Deployments that misconfigure the web server to serve `secure/`
 *        directly are a DEPLOYMENT bug, not a QuickSite vulnerability.
 *        Audit your deployment config before going live (`curl
 *        https://your-site.com/secure/admin/config/api-secrets.php` MUST
 *        return 404, never 200 with file contents).
 *
 *     3. File-system permissions matter on multi-tenant hosts. The web
 *        user owns this file; nothing else should have read access.
 *
 *
 * STORAGE:
 *
 *   - This file is the GITIGNORED actual config: `api-secrets.php`. It
 *     is shipped alongside this `.example` template — copy + rename to
 *     activate. Mirrors the existing `secure/management/config/auth.php`
 *     +  `.example` pattern.
 *
 *   - One entry per API id (matches the `apiId` in api-endpoints.json).
 *     The value is the raw key/token sent to the upstream API. The
 *     endpoint's auth config (`tokenSource: 'header:X-API-Key'` etc.)
 *     decides which HEADER name carries it.
 *
 *
 * SHAPE:
 *
 *   return [
 *       '<apiId>' => '<raw secret value>',
 *       ...
 *   ];
 *
 *
 * EXAMPLE:
 *
 *   return [
 *       // Stripe REST API — header: 'Authorization: Bearer sk_test_…'
 *       // (api-endpoints.json has apiId='stripe' + auth.type=apiKey +
 *       //  tokenSource='header:Authorization' + a "Bearer " prefix on the
 *       //  endpoint's auth config — TODO confirm the prefix-handling design)
 *       'stripe' => 'sk_test_abc123…',
 *
 *       // Sendgrid mail send — header: 'X-API-Key: SG.xyz…'
 *       'sendgrid' => 'SG.xyz…',
 *   ];
 *
 *
 * NULL / MISSING VALUES:
 *
 *   If an apiKey endpoint is called and its apiId has no entry here,
 *   serverFetch returns ok=false with a clear "apiKey not configured"
 *   error. The resolver decides whether to 500 or render the route's
 *   `onMiss` fallback. Either way the upstream call is NOT attempted
 *   with an empty key.
 */

return [
    // Add entries as needed. Empty array is a valid starting point —
    // resolvers only consult this file when an apiKey-typed endpoint
    // actually fires.
];
