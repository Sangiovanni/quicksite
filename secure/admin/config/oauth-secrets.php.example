<?php
/**
 * oauth-secrets.php — Per-provider OAuth client credentials (beta.9 A1).
 *
 * Used by OAuthHandler when exchanging an authorization code for tokens.
 * One entry per provider id (matches keys in oauth-presets.json).
 *
 *
 * SECURITY DISCLOSURE — read before committing the `.php` sibling:
 * (mirrors api-secrets.php.example's disclosure — same security boundary)
 *
 *   Anyone with FILESYSTEM access to `secure/` can read these secrets.
 *   That is BY DESIGN — server-side PHP code needs them to exchange the
 *   OAuth code with the provider. But it means:
 *
 *     1. DO NOT put `secure/` inside any web-served directory. The split
 *        between `public/` (web-served) and `secure/` (require_once-only)
 *        exists exactly for this reason — see ARCHITECTURE.md §7
 *        "Security boundary".
 *
 *     2. Deployments that misconfigure the web server to serve `secure/`
 *        directly are a DEPLOYMENT bug, not a QuickSite vulnerability.
 *        Audit your deployment config before going live (`curl
 *        https://your-site.com/secure/admin/config/oauth-secrets.php`
 *        MUST return 404, never 200 with file contents).
 *
 *     3. File-system permissions matter on multi-tenant hosts. The web
 *        user owns this file; nothing else should have read access.
 *
 *     4. A leaked client_secret lets attackers impersonate YOUR app
 *        against the provider — they could phish your users via
 *        look-alike sites that exchange codes using your credentials.
 *        Rotate immediately if you suspect exposure.
 *
 *
 * STORAGE:
 *
 *   - This file is the GITIGNORED actual config: `oauth-secrets.php`.
 *     It is shipped alongside this `.example` template — copy + rename
 *     to activate. Mirrors `api-secrets.php` / `api-secrets.php.example`.
 *
 *   - Dedicated file (not folded into api-secrets.php) per the OAuth
 *     design decision (locked 2026-06-11) — provider credentials have
 *     a different lifecycle (rotated in each provider's console) and
 *     blast radius (account impersonation, not just data access) from
 *     general API secrets.
 *
 *
 * LOOKUP ORDER (Slice 2.5, locked 2026-06-15 — "per-project config"):
 *
 *   OAuthHandler::loadSecret looks up credentials in this order:
 *
 *     1. Per-project: `secure/projects/<active>/data/oauth-secrets.json`
 *        (JSON; gitignored by the engine's `.gitignore` rule). PRIMARY
 *        for the typical case where each project registers its own
 *        OAuth app with each provider (different `client_id` per
 *        project — usually what you want for security + analytics).
 *     2. Admin fallback: THIS FILE. FALLBACK for credentials shared
 *        across every project on the install — usually only the
 *        dev test-oauth fixture creds and any "personal Google /
 *        GitHub app I always use" kind of entry.
 *
 *   Override is at PROVIDER level (full-entry replace, NOT field-level
 *   merge). If the project file declares `google`, it owns google
 *   entirely; admin's google is ignored for that project.
 *
 *   Per-project file shape (mirror this file's shape but JSON):
 *
 *     {
 *       "google": {
 *         "client_id":     "1234.apps.googleusercontent.com",
 *         "client_secret": "GOCSPX-..."
 *       },
 *       "mycorp-sso": {
 *         "client_id":     "internal-app-id",
 *         "client_secret": "internal-secret"
 *       }
 *     }
 *
 *
 * SHAPE:
 *
 *   return [
 *       '<providerId>' => [
 *           'client_id'     => '<value from the provider\'s console>',
 *           'client_secret' => '<value from the provider\'s console>',
 *       ],
 *       ...
 *   ];
 *
 *   The <providerId> string must match a key in
 *   secure/admin/config/oauth-presets.json (the preset declares the
 *   URLs + scope; this file declares the credentials).
 *
 *
 * EXAMPLE:
 *
 *   return [
 *       // Google Cloud Console: APIs & Services → Credentials → OAuth 2.0
 *       'google' => [
 *           'client_id'     => '123456789-abc...apps.googleusercontent.com',
 *           'client_secret' => 'GOCSPX-abc...',
 *       ],
 *
 *       // GitHub: Settings → Developer settings → OAuth Apps
 *       'github' => [
 *           'client_id'     => 'Iv1.abc...',
 *           'client_secret' => 'github_secret_value',
 *       ],
 *
 *       // Meta for Developers: My Apps → <app> → Settings → Basic
 *       'meta' => [
 *           'client_id'     => '1234567890123456',
 *           'client_secret' => 'meta_secret_value',
 *       ],
 *
 *       // Amazon Developer Console: Login with Amazon → Security Profile
 *       'amazon' => [
 *           'client_id'     => 'amzn1.application-oa2-client.abc...',
 *           'client_secret' => 'amazon_secret_value',
 *       ],
 *   ];
 *
 *
 * MISSING ENTRIES:
 *
 *   If an OAuth flow fires for a providerId that has no entry here,
 *   OAuthHandler::__construct throws a clear "secrets missing" error
 *   pointing back at this file. The flow never reaches the provider
 *   with empty credentials.
 */

return [
    // Add entries as needed. Empty array is a valid starting point —
    // OAuthHandler only consults this file when a flow actually fires
    // for the given provider id.
];
