<?php
/**
 * User Registry — stable userId => identity. Engine plumbing (PHP).
 *
 * Copy this file to users.php. Login is USERNAME + PASSWORD (C5b; username
 * identity C8 8.0b): the login command / admin login page verify the password
 * against `password_hash` and issue a short-lived session (see auth.php
 * `session` knobs). The username is PRIVATE (login-only — never shown to
 * other users); public identity is the display `name` + the user id. There
 * is NO email field (a mailer-less system cannot verify or use one) and NO
 * global "superadmin" role: a user simply owns / is a member of projects, and
 * their capabilities come from their per-project role
 * (owner/admin/developer/designer/editor/viewer) recorded in each project's
 * config/members.json. A brand-new user with no projects can still create one
 * (createProject) and becomes its owner.
 *
 * Generate a real userId with: php -r "echo 'usr_' . bin2hex(random_bytes(16));"
 * Generate a password hash with: php -r "echo password_hash('your-password', PASSWORD_DEFAULT);"
 *
 * Fields:
 *   name             public display name (shown in the admin panel and to
 *                    other users)
 *   username         PRIVATE login identifier (unique; 3-32 characters,
 *                    lowercase letters/digits/dash/underscore; null = cannot
 *                    log in by password)
 *   status           'active' | 'disabled' (disabled = every session rejected)
 *   password_hash    password_hash() output; null = externally managed account
 *                    (its sessions are minted by an embedding platform, never
 *                    by the login page)
 *   selected_project the project opened by default (UX only — never authorization)
 *   projects         status MIRROR of "my projects" (never authoritative —
 *                    access always re-checks the project's members.json).
 *                    Each entry carries a `status`: 'member' (missing =
 *                    member, pre-8.3a entries), 'pending_invite' /
 *                    'pending_request' (awaiting consent — never grants
 *                    access), or a terminal notice 'refused' / 'removed' /
 *                    'deleted' (dismissable via dismissProjectNotice).
 *                    'member' entries are rebuildable from members.json;
 *                    pending/terminal statuses are NOT — a cache repair
 *                    (reconcileMemberships) must merge-preserve them.
 */

return [
    'users' => [
        // Default account — password is 'CHANGE_ME_admin' (public knowledge!).
        // Change the password_hash AND the userId before deploying; the admin
        // panel shows a security warning as long as this account exists.
        'usr_CHANGE_ME_default' => [
            'name'             => 'Default Admin',
            'username'         => 'admin',
            'status'           => 'active',
            'password_hash'    => '$2y$10$v8pm2uxDZ.qdwA5LgF.Yt.96LYs9svgaAsJ2c//X4P0X4BTVig4QO',
            'selected_project' => null,
            'projects'         => [],
        ],
    ],
];
