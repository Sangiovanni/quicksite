<?php
/**
 * Authentication & CORS Configuration
 *
 * Copy this file to auth.php and customize.
 *
 * The token is the credential (it "logs you in"); it resolves to a USER in
 * users.php (copy users.php.example alongside this). Per-project roles live in
 * each project's config/members.json — NOT here.
 *
 * IMPORTANT: Replace the default token before deploying to production!
 * Generate a secure token with: php -r "echo 'tvt_' . bin2hex(random_bytes(24));"
 * and point its userId at a real entry in users.php.
 */

return [
    'authentication' => [
        'enabled' => true,
        'tokens' => [
            // Default token — change this before deploying! Resolves to the
            // 'usr_CHANGE_ME_default' user in users.php.example. The admin panel's
            // default-token security warning detects any key containing 'CHANGE_ME'.
            'CHANGE_ME_default_token' => [
                'userId' => 'usr_CHANGE_ME_default',
                'created' => '2026-01-01',
            ],
        ],
    ],
    'cors' => [
        'enabled' => true,
        'allowed_origins' => ['*'],
        'allowed_methods' => ['POST', 'OPTIONS'],
        'allowed_headers' => ['Content-Type', 'Authorization', 'Accept-Language'],
        'max_age' => 3600,
    ],
];
