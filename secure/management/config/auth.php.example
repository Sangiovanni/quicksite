<?php
/**
 * Authentication & CORS Configuration
 *
 * Copy this file to auth.php and customize.
 *
 * C5b/C8 8.0b: credentials are USERNAME + PASSWORD — see users.php(.example)
 * `password_hash`. Runtime sessions (short-lived access token + rotating
 * refresh token) live in sessions.json next to this file (machine-written,
 * auto-created — never edit or commit it). This file holds the session TTL
 * knobs, the self-registration gate, and CORS.
 */

return [
    'authentication' => [
        // Session lifecycle knobs (seconds).
        'session' => [
            'access_ttl'  => 900,       // access-token lifetime (15 min)
            'refresh_ttl' => 2592000,   // refresh-token lifetime, sliding (30 days)
            'reuse_grace' => 60,        // window in which a rotated refresh token's
                                        // reuse is treated as a legit race (two tabs),
                                        // not theft
        ],
        // Self-registration policy. allow_self_registration false (secure
        // default) = no register page, no public register command; accounts
        // exist from setup (users.php) only. When true, /admin/register and
        // POST /management/register create accounts, subject to the flood
        // controls below. min_password_length also applies to changePassword.
        // For every limit: 0 = no limit.
        'registration' => [
            'allow_self_registration' => false,
            'min_password_length'     => 12,   // register + changePassword
            'max_users'               => 0,    // absolute account cap (users.php entries)
            'throttle' => [
                'per_ip_per_minute' => 3,      // register attempts per IP per minute
                'global_per_hour'   => 30,     // successful registrations per hour, install-wide
            ],
        ],
    ],
    'cors' => [
        'enabled' => true,
        'allowed_origins' => ['*'],
        'allowed_methods' => ['POST', 'OPTIONS'],
        'allowed_headers' => ['Content-Type', 'Authorization', 'Accept-Language'],
        'max_age' => 3600,
    ],
];
